@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">TechMove Management System</h1>
    <p class="lead">Manage Clients, Contracts, and Service Requests</p>
</div>

<hr />

<div class="row mt-4">

    <!-- Clients -->
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body text-center">
                <h4 class="card-title">Clients</h4>
                <p>Manage client information and regions.</p>
                <a asp-controller="Clients" asp-action="Index" class="btn btn-primary">
                    View Clients
                </a>
            </div>
        </div>
    </div>

    <!-- Contracts -->
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body text-center">
                <h4 class="card-title">Contracts</h4>
                <p>Create and manage contracts, upload agreements.</p>
                <a asp-controller="Contracts" asp-action="Index" class="btn btn-success">
                    View Contracts
                </a>
            </div>
        </div>
    </div>

    <!-- Service Requests -->
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body text-center">
                <h4 class="card-title">Service Requests</h4>
                <p>Track requests and convert USD to ZAR.</p>
                <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-warning">
                    View Requests
                </a>
            </div>
        </div>
    </div>

</div>

<hr />

<div class="text-center mt-4">
    <h5>System Features</h5>
    <ul class="list-unstyled">
        <li>✔ Client Management</li>
        <li>✔ Contract Lifecycle (Draft → Active → Expired)</li>
        <li>✔ PDF Agreement Upload & Download</li>
        <li>✔ Service Request Workflow Validation</li>
        <li>✔ Currency Conversion (USD → ZAR)</li>
        <li>✔ Search & Filter Contracts</li>
    </ul>
</div>