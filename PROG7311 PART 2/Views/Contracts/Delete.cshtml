@model Contract

<h2>Delete Contract</h2>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this contract?</strong>
</div>

<div class="card p-3 mb-3">
    <p><strong>Client:</strong> @Model.Client?.Name</p>
    <p><strong>Start Date:</strong> @Model.StartDate.ToShortDateString()</p>
    <p><strong>End Date:</strong> @Model.EndDate.ToShortDateString()</p>
    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Service Level:</strong> @Model.ServiceLevel</p>
</div>


<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="ContractId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>